# Required
OPENAI_API_KEY=sk-...

# Optional – override the defaults in config.py
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
CHROMA_DIR=./chroma_store
KB_DIR=./knowledge_base
DATA_DIR=./data
AUDIT_LOG_PATH=./data/audit_log.jsonl

# Behavior
AUTO_APPROVE_LOW_RISK=true       # auto-grant low-risk groups w/o human review
LOG_LEVEL=INFO
